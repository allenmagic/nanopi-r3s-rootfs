# ============================================================
# sing-box 栈系统包列表
#
# 语法说明：
#   - 以 # 开头的行为注释，被忽略
#   - 无前缀的行 = 所有 OS 都安装
#   - [os] 前缀 = 仅在该 OS 安装，os 可用值：
#     void / debian / devuan / alpine
#   - 多个 OS 用逗号分隔，如 [void,alpine]
# ============================================================

# ---- 公共包（所有 OS 均安装） ----
dnsmasq
nftables
openssh
chrony
curl

# ---- OS 专属包 ----
# 有包管理器的优先用包，没有再走 GitHub Release / 静态下载（见 install.sh）
[void]          tailscale
[void]          sing-box
[void]          runit-nftables
[void]          iproute2

[alpine]        tailscale
[alpine]        sing-box
[alpine]        openrc

[debian]        tailscale
[debian]        systemd

# Devuan sysvinit 已由 mmdebstrap minbase 提供
# Devuan 没有 tailscale / sing-box 包，走静态下载或 GitHub Release 兜底
