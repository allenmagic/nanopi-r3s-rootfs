#!/bin/sh
### BEGIN INIT INFO
# Provides:          sing-box
# Required-Start:    $network $remote_fs
# Required-Stop:     $network
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: sing-box proxy
### END INIT INFO

DAEMON=/usr/local/bin/sing-box
PIDFILE=/var/run/sing-box.pid

case "$1" in
    start)
        echo "Starting sing-box..."
        start-stop-daemon --start --background --make-pidfile \
            --pidfile "$PIDFILE" --exec "$DAEMON" -- run -D /etc/sing-box
        ;;
    stop)
        echo "Stopping sing-box..."
        start-stop-daemon --stop --pidfile "$PIDFILE" || true
        rm -f "$PIDFILE"
        ;;
    restart) "$0" stop; "$0" start ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "sing-box is running"
        else
            echo "sing-box is not running"
            return 1
        fi
        ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
