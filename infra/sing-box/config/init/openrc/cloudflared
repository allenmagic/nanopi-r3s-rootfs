#!/sbin/openrc-run

name=$RC_SVCNAME
description="Cloudflare Tunnel"

command="/usr/local/bin/cloudflared"
command_args="--no-autoupdate tunnel run"
command_background="yes"
pidfile="/var/run/$name.pid"
output_log="/var/log/$name.log"
error_log="/var/log/$name.log"

depend() {
    need net
    after firewall
    use logger dns
}

