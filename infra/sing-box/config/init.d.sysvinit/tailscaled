#!/bin/sh
### BEGIN INIT INFO
# Provides:          tailscaled
# Required-Start:    $network $remote_fs
# Required-Stop:     $network
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: tailscale agent
### END INIT INFO

DAEMON=/usr/local/bin/tailscaled
FLAGS="--state=/var/lib/tailscale/tailscaled.state --socket=/var/run/tailscale/tailscaled.sock"
PIDFILE=/var/run/tailscaled.pid

case "$1" in
    start)
        echo "Starting tailscaled..."
        mkdir -p /var/lib/tailscale /var/run/tailscale
        start-stop-daemon --start --background --make-pidfile \
            --pidfile "$PIDFILE" --exec "$DAEMON" -- $FLAGS
        ;;
    stop)
        echo "Stopping tailscaled..."
        start-stop-daemon --stop --pidfile "$PIDFILE" || true
        rm -f "$PIDFILE"
        ;;
    restart) "$0" stop; "$0" start ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "tailscaled is running"
        else
            echo "tailscaled is not running"
            return 1
        fi
        ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
