# ============================================================
# Void Linux 包列表
#
# 语法：
#   [pm] <package>                —— 包管理器安装（xbps-install）
#   [dl@<url>] <binary_name>      —— 下载 URL 到 /usr/local/bin/<binary_name>
#                                   自动解压 .tar.gz，查找二进制文件
#
# 三段式：base / router / landscape
# ============================================================

# ========== base ==========
[pm] openssh
[pm] chrony
[pm] curl
[pm] ncurses
[pm] ncurses-base

# ========== sing-box ==========
[pm] dnsmasq
[pm] nftables
[pm] runit-nftables
[pm] tailscale
[pm] iproute2
[pm] cloudflared
[pm] sing-box

# ========== landscape ==========
