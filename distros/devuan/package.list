# ============================================================
# Devuan 包列表
#
# 语法：
#   [pm] <package>                —— 包管理器安装（apt-get）
#   [dl@<url>] <binary_name>      —— 下载 URL 到 /usr/local/bin/<binary_name>
#                                   自动解压 .tar.gz，查找二进制文件
#
# 三段式：base / router / landscape
# ============================================================

# ========== base ==========
[pm] openssh-server
[pm] chrony
[pm] curl
[pm] ncurses-bin
[pm] ncurses-base

# ========== router ==========
[pm] dnsmasq
[pm] nftables
[dl@https://pkgs.tailscale.com/stable/tailscale_latest_arm64.tgz] tailscale
[dl@https://github.com/sagernet/sing-box/releases/download/v1.10.0/sing-box-1.10.0-linux-arm64.tar.gz] sing-box
[dl@https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-arm64] cloudflared

# ========== landscape ==========
